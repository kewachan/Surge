#!name=Youtube Enhance
#!desc=Enhancements for YouTube and YouTube Music
#!arguments=Block Upload Button:true,Block Immersive Button:true,Block Shorts Button:false,Caption Translation Language:off,Enable Debug Mode:false
#!arguments-desc=- Blocking options: [true, false] \n- Translation option: [language code, off] \n\n1. Language codes follow the Google Translate language codes. Use off to disable translation.\n2. Enable debug mode to output additional logs.


[Script]
youtube.response = type=http-response,pattern=^https:\/\/youtubei\.googleapis\.com\/(youtubei\/v1\/(browse|next|player|search|reel\/reel_watch_sequence|guide|account\/get_setting|get_watch|log_event|config))(\?(.*))?$,requires-body=1,max-size=-1,binary-body-mode=1,script-path=https://raw.githubusercontent.com/kewachan/Surge/main/Rewrite/Youtube/youtube.response.js,argument="{"captionLang":"{{{Caption Translation Language}}}","blockUpload":{{{Block Upload Button}}},"blockImmersive":{{{Block Immersive Button}}},"blockShorts":{{{Block Shorts Button}}},"debug":{{{Enable Debug Mode}}}}"
youtube.request.init = type=http-request,pattern=^https?:\/\/[\w-]+\.googlevideo\.com\/initplayback.+&ack.*,requires-body=1,max-size=-1,binary-body-mode=1,script-path=https://raw.githubusercontent.com/kewachan/Surge/main/Rewrite/Youtube/youtube.request.js,argument="{"captionLang":"{{{Caption Translation Language}}}"}"
youtube.request.log_event = type=http-request,pattern=^https:\/\/youtubei\.googleapis\.com\/youtubei\/v1\/log_event,requires-body=1,max-size=-1,binary-body-mode=1,script-path=https://raw.githubusercontent.com/kewachan/Surge/main/Rewrite/Youtube/youtube.request.js
youtube.caption.request = type=http-request,pattern=^https:\/\/www\.youtube\.com\/api\/timedtext\?(?:[^&]*&)*tlang=[^&]+(?:&|$),script-path=https://raw.githubusercontent.com/kewachan/Surge/main/Rewrite/Youtube/youtube.caption.js
youtube.caption.response = type=http-response,pattern=^https:\/\/www\.youtube\.com\/api\/timedtext\?(?:[^&]*&)*(?:enhance_)?tlang=[^&]+(?:&|$),requires-body=1,max-size=-1,script-path=https://raw.githubusercontent.com/kewachan/Surge/main/Rewrite/Youtube/youtube.caption.js

[MITM]
hostname = %APPEND% *.googlevideo.com, youtubei.googleapis.com, www.youtube.com
