#!name=Youtube Enhance
#!desc=Enhancements for YouTube and YouTube Music
#!arguments=Block Upload Button:true,Block Immersive Button:true,Block Shorts Button:false,Caption Translation Language:off,Regional Fallback:false,Fallback Group:YouTube Region,Fallback Policy:Japan,Restore After Minutes:120,Enable Debug Mode:false
#!arguments-desc=- Blocking and fallback options: [true, false] \n- Translation option: [language code, off] \n- Fallback Group: a dedicated Surge select group used by your local YouTube rules \n- Fallback Policy: an existing policy inside that select group \n\n1. Language codes follow the Google Translate language codes. Use off to disable translation.\n2. Regional fallback only triggers for an explicit country or region restriction. It does not bypass Premium, sign-in, age, copyright, or bot checks.\n3. Route youtubei.googleapis.com, *.googlevideo.com, and youtube-init.hmtw47cv7m.workers.dev to Fallback Group in your local Surge rules.\n4. Keep Cloudflare Worker Smart Placement disabled so it runs near the incoming fallback route.\n5. Enable debug mode to output additional logs.


[Script]
youtube.response = type=http-response,pattern=^https:\/\/youtubei\.googleapis\.com\/(youtubei\/v1\/(browse|next|player|search|reel\/reel_watch_sequence|guide|account\/get_setting|get_watch|log_event|config))(\?(.*))?$,requires-body=1,max-size=-1,binary-body-mode=1,timeout=15,script-path=https://raw.githubusercontent.com/kewachan/Surge/main/Rewrite/Youtube/youtube.response.js,argument="{"captionLang":"{{{Caption Translation Language}}}","blockUpload":{{{Block Upload Button}}},"blockImmersive":{{{Block Immersive Button}}},"blockShorts":{{{Block Shorts Button}}},"regionFallback":{{{Regional Fallback}}},"fallbackGroup":"{{{Fallback Group}}}","fallbackPolicy":"{{{Fallback Policy}}}","restoreMinutes":{{{Restore After Minutes}}},"debug":{{{Enable Debug Mode}}}}"
youtube.request.player = type=http-request,pattern=^https:\/\/youtubei\.googleapis\.com\/youtubei\/v1\/(player|get_watch)(\?.*)?$,requires-body=1,max-size=-1,binary-body-mode=1,script-path=https://raw.githubusercontent.com/kewachan/Surge/main/Rewrite/Youtube/youtube.request.js,argument="{"regionFallback":{{{Regional Fallback}}},"fallbackGroup":"{{{Fallback Group}}}","fallbackPolicy":"{{{Fallback Policy}}}","restoreMinutes":{{{Restore After Minutes}}},"debug":{{{Enable Debug Mode}}}}"
youtube.request.init = type=http-request,pattern=^https?:\/\/[\w-]+\.googlevideo\.com\/initplayback.+&ack.*,requires-body=1,max-size=-1,binary-body-mode=1,script-path=https://raw.githubusercontent.com/kewachan/Surge/main/Rewrite/Youtube/youtube.request.js,argument="{"captionLang":"{{{Caption Translation Language}}}","regionFallback":{{{Regional Fallback}}},"fallbackGroup":"{{{Fallback Group}}}","fallbackPolicy":"{{{Fallback Policy}}}","restoreMinutes":{{{Restore After Minutes}}},"debug":{{{Enable Debug Mode}}}}"
youtube.request.log_event = type=http-request,pattern=^https:\/\/youtubei\.googleapis\.com\/youtubei\/v1\/log_event,requires-body=1,max-size=-1,binary-body-mode=1,script-path=https://raw.githubusercontent.com/kewachan/Surge/main/Rewrite/Youtube/youtube.request.js
youtube.caption.request = type=http-request,pattern=^https:\/\/www\.youtube\.com\/api\/timedtext\?(?:[^&]*&)*tlang=[^&]+(?:&|$),timeout=10,script-path=https://raw.githubusercontent.com/kewachan/Surge/main/Rewrite/Youtube/youtube.caption.js
youtube.caption.response = type=http-response,pattern=^https:\/\/www\.youtube\.com\/api\/timedtext\?(?:[^&]*&)*(?:enhance_)?tlang=[^&]+(?:&|$),requires-body=1,max-size=-1,timeout=30,script-path=https://raw.githubusercontent.com/kewachan/Surge/main/Rewrite/Youtube/youtube.caption.js

[MITM]
hostname = %APPEND% *.googlevideo.com, youtubei.googleapis.com, www.youtube.com
