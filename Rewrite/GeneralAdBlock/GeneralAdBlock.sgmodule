#!name=General AdBlock
#!desc=HAR-driven general advertising blocker
#!system=ios

[Script]
Google Search App Promo = type=http-response, pattern=^https:\/\/www\.google\.com\/search\?, requires-body=true, max-size=0, script-path=https://raw.githubusercontent.com/kewachan/Surge/main/Rewrite/GeneralAdBlock/general-adblock.js

[MITM]
hostname = %APPEND% www.google.com
