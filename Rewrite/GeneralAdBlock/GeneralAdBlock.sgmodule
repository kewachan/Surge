#!name=General AdBlock
#!desc=HAR-driven general advertising blocker
#!system=ios

[Script]
Google Search & Shopping Ads = type=http-response, pattern=^https:\/\/www\.google\.com\/(?:search|shopping)(?:\/.*)?(?:\?.*)?$, requires-body=true, max-size=0, script-path=https://raw.githubusercontent.com/kewachan/Surge/main/Rewrite/GeneralAdBlock/general-adblock.js?v=067a15e

[MITM]
hostname = %APPEND% www.google.com
