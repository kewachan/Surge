#!name=General AdBlock
#!desc=HAR-driven general advertising blocker
#!system=ios

[Script]
GeneralAdBlock = type=rule,script-path=https://raw.githubusercontent.com/kewachan/Surge/main/Rewrite/GeneralAdBlock/general-adblock.js,script-update-interval=86400,timeout=5

[Rule]
SCRIPT,GeneralAdBlock,REJECT

[URL Rewrite]
# Bilibili pause-page advertisement
^https:\/\/grpc\.biliapi\.net\/bilibili\.app\.viewunite\.v1\.View\/PlayPause$ _ reject

[MITM]
hostname = %APPEND% grpc.biliapi.net
